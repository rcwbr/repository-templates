(.repos[] | select(.repo == "https://github.com/pre-commit/pre-commit-hooks").hooks[] | select(.id == "double-quote-string-fixer")) |= .exclude = (load(".pre-commit-config.extend.yaml").repos[] | select(.repo == "https://github.com/pre-commit/pre-commit-hooks").hooks[] | select(.id == "double-quote-string-fixer").exclude)
| .repos = [load(".pre-commit-config.extend.yaml").repos[] | select(.repo == "https://github.com/psf/black-pre-commit-mirror")] + .repos
