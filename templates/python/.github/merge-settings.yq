.rulesets[] |= select(.name == "Default branch rules").rules |= map(select(.type == "required_status_checks").parameters.required_status_checks += (load("settings.extend.yml").rulesets[0].rules[0].parameters.required_status_checks)) | .rulesets += (load("settings.extend.yml").rulesets[1:]) | .environments += (load("settings.extend.yml").environments)
